# Supabase (server-side — a SERVICE_KEY NUNCA vai para o frontend)
SUPABASE_URL=https://xxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=seu-service-role-key

# Cloudinary (modo Fetch — só o cloud_name é necessário para montar URLs)
CLOUDINARY_CLOUD_NAME=seu-cloud-name

# Usadas APENAS pelos scripts de seeding (não pelo servidor em runtime)
TMDB_API_KEY=
RAWG_API_KEY=          # rawg.io → Developer → API key (free)
FREESOUND_API_KEY=     # freesound.org → API → Apply for credentials (free)
GEMINI_API_KEY=        # aistudio.google.com → Get API key (free tier)

# CORS: origens do frontend (separadas por vírgula)
CORS_ORIGINS=http://localhost:5173

# Parâmetros default de partida
DEFAULT_ROUND_DURATION=20
DEFAULT_TOTAL_ROUNDS=10
